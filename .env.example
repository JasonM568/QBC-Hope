# =============================================================================
# HOPE OS — 環境變數範例
#
# 用法：
#   cp .env.example .env.local
#   填入真實值（.env.local 已加入 .gitignore，不會 commit）
#
# 部署到 Vercel：上 Vercel Dashboard 的 Environment Variables 設定，
#   建議用 `vercel env pull` 同步本地。
# =============================================================================

# -----------------------------
# Supabase
# -----------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------
# Site
# -----------------------------
# 公開可達網址（綠界 callback / return URL 都從這裡組）
NEXT_PUBLIC_SITE_URL=https://hope.huangxi.info

# -----------------------------
# LINE Bot
# -----------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# =============================================================================
# 綠界（ECPay）金流
#
# 切換：
#   ECPAY_ENV=stage  → 走測試環境，缺值會自動 fallback 至綠界公開測試帳號
#   ECPAY_ENV=prod   → 走正式環境，所有 MERCHANT_ID/HASH_KEY/HASH_IV 必填
#
# 測試帳號（stage 才能用，已內建 fallback，不必填）：
#   MerchantID = 3002607
#   HashKey    = pwFHCqoQZGmho4w6
#   HashIV     = EkRm7iFT261dpevs
# =============================================================================
ECPAY_ENV=stage

# 正式帳號（向綠界申請後填入；prod 必填）
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=

# -----------------------------
# 電子發票（一體式整合，AioCheckOut InvoiceMark=Y）
#
# 綠界發票會顯示「賣方」資訊：
#   - INVOICE_SELLER_IDENTIFIER：賣方統編（HOPE 公司統編）
#   - INVOICE_SELLER_NAME：賣方抬頭（顯示在發票上的公司名）
#
# 兩者由綠界後台同步綁定，這裡僅作為前端 / log 顯示用。
# -----------------------------
ECPAY_INVOICE_SELLER_IDENTIFIER=
ECPAY_INVOICE_SELLER_NAME=HOPE
